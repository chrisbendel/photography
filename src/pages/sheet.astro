---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const photos = (await getCollection("photos", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Contact sheet — Chris Bendel" description="All photographs, at a glance.">
	<section class="intro">
		<h1>Contact sheet</h1>
		<p>Every frame. Click any to read.</p>
	</section>

	<div class="sheet">
		{
			photos.map((photo) => (
				<a href={`/photos/${photo.id}/`} class="cell" aria-label={photo.data.title}>
					<Image
						src={photo.data.image}
						alt={photo.data.alt}
						widths={[200, 400, 600]}
						sizes="(min-width: 700px) 220px, 45vw"
						loading="lazy"
					/>
				</a>
			))
		}
	</div>
</Layout>

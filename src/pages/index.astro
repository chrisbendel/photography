---
import { Image } from "astro:assets";
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { byNewest, formatLabel } from "../lib/format";

const allPhotos = (await getCollection("photos")).sort(byNewest);

const photo = allPhotos[0];
const seriesEntry = photo?.data.series ? await getEntry(photo.data.series) : null;
const fmtMonthYear = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });

const versoLine = photo
	? [
			seriesEntry?.data.title,
			photo.data.format && formatLabel(photo.data.format),
			photo.data.date && fmtMonthYear.format(photo.data.date),
			photo.data.location,
		]
			.filter(Boolean)
			.join(" · ")
	: "";
---

<Layout title="Chris Bendel — Photography" description="Selected film photography.">
	{
		photo ? (
			<figure class="home">
				<a href={`/photos/${photo.id}/`}>
					<Image
						src={photo.data.image}
						alt={photo.data.alt}
						widths={[640, 960, 1280, 1600]}
						sizes="(min-width: 700px) 36rem, 100vw"
						loading="eager"
					/>
				</a>
				{versoLine && <figcaption class="verso">{versoLine}</figcaption>}
			</figure>
		) : (
			<section class="intro">
				<h1>Photographs</h1>
				<p><em>No photographs published yet.</em></p>
			</section>
		)
	}
</Layout>

<style>
	figure.home {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	figure.home a {
		display: block;
		line-height: 0;
	}

	figure.home img {
		display: block;
		width: 100%;
		height: auto;
	}

	figure.home .verso {
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		font-size: 0.72rem;
		color: var(--ink-faint);
		margin: 0;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
</style>

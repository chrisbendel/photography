---
import { Image } from "astro:assets";
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { formatLabel, sortKey } from "../lib/format";

const allPhotos = (await getCollection("photos", ({ data }) => !data.draft)).sort(
	(a, b) => sortKey(b) - sortKey(a),
);

const photo = allPhotos[0];
const seriesEntry = photo?.data.series ? await getEntry(photo.data.series) : null;
const fmtMonthYear = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });
---

<Layout title="Chris Bendel — Photography" description="Selected film photography.">
	{
		photo ? (
			<article class="home">
				<a href={`/photos/${photo.id}/`} class="home-figure">
					<Image
						src={photo.data.image}
						alt={photo.data.alt}
						widths={[640, 960, 1280, 1600]}
						sizes="(min-width: 700px) 36rem, 100vw"
						loading="eager"
					/>
				</a>
				<div class="home-meta">
					<h1>{photo.data.title}</h1>
					<p class="verso">
						{[
							seriesEntry?.data.title,
							photo.data.format && formatLabel(photo.data.format),
							fmtMonthYear.format(photo.data.date),
							photo.data.location,
						]
							.filter(Boolean)
							.join(" · ")}
					</p>
				</div>
			</article>
		) : (
			<section class="intro">
				<h1>Photographs</h1>
				<p><em>No photographs published yet.</em></p>
			</section>
		)
	}
</Layout>

<style>
	.home {
		display: flex;
		flex-direction: column;
		gap: var(--gap);
	}

	.home > * {
		margin: 0;
	}

	.home-figure {
		display: block;
	}

	.home-figure img {
		display: block;
		width: 100%;
		height: auto;
	}

	.home-meta h1 {
		margin: 0.5rem 0 0;
	}

	.verso {
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		font-size: 0.72rem;
		color: var(--ink-faint);
		margin: 0.25rem 0 0;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
</style>

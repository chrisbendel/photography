---
import { Image } from "astro:assets";
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const photos = await getCollection("photos", ({ data }) => !data.draft);
	return photos.map((photo) => ({
		params: { id: photo.id },
		props: { photo },
	}));
}

const { photo } = Astro.props;
const { Content } = await render(photo);
const { title, date, image, alt, caption, camera, film, location, format, series, tags } = photo.data;
const seriesEntry = series ? await getEntry(series) : null;
const fmt = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });
---

<Layout title={`${title} — Chris Bendel`} description={alt}>
	{
		seriesEntry && (
			<p class="eyebrow">
				<a href={`/series/${seriesEntry.id}/`}>← {seriesEntry.data.title}</a>
			</p>
		)
	}

	<figure class="print-figure" data-invert="false">
		<div class="print-frame">
			<Image src={image} alt={alt} loading="eager" class="print-img" />
			<button
				type="button"
				class="invert-btn"
				aria-pressed="false"
				aria-label="Toggle negative"
				title="View as negative"
			>
				<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
					<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.6" />
					<path d="M 12 3 A 9 9 0 0 1 12 21 Z" fill="currentColor" />
				</svg>
			</button>
		</div>
		{caption && <figcaption>{caption}</figcaption>}
	</figure>

	<script is:inline>
		(function () {
			const figs = document.querySelectorAll(".print-figure");
			figs.forEach((fig) => {
				const btn = fig.querySelector(".invert-btn");
				if (!btn) return;
				btn.addEventListener("click", () => {
					const inverted = fig.getAttribute("data-invert") === "true";
					const next = !inverted;
					fig.setAttribute("data-invert", String(next));
					btn.setAttribute("aria-pressed", String(next));
					btn.setAttribute(
						"title",
						next ? "View as positive" : "View as negative",
					);
				});
			});
		})();
	</script>

	<h1>{title}</h1>

	<dl class="photo-meta">
		<dt>Date</dt>
		<dd>{fmt.format(date)}</dd>
		{location && (<><dt>Location</dt><dd>{location}</dd></>)}
		{camera && (<><dt>Camera</dt><dd>{camera}</dd></>)}
		{film && (<><dt>Film</dt><dd>{film}</dd></>)}
		{format && (<><dt>Format</dt><dd>{format.replace("x", "×")}</dd></>)}
	</dl>

	<section class="notes">
		<h2>Notes</h2>
		<Content />
	</section>

	{
		tags && tags.length > 0 && (
			<p class="photo-tags">
				{tags.map((t, i) => (
					<>
						{i > 0 && ", "}
						<a href={`/tags/${t}/`}>{t}</a>
					</>
				))}
			</p>
		)
	}
</Layout>

---
import { Image } from "astro:assets";
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const photos = await getCollection("photos", ({ data }) => !data.draft);
	return photos.map((photo) => ({
		params: { id: photo.id },
		props: { photo },
	}));
}

const { photo } = Astro.props;
const { Content } = await render(photo);
const { title, date, image, alt, caption, camera, film, location, format, series, tags } = photo.data;
const seriesEntry = series ? await getEntry(series) : null;
const fmt = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });
---

<Layout title={`${title} — Chris Bendel`} description={alt}>
	{
		seriesEntry && (
			<p class="eyebrow">
				<a href={`/series/${seriesEntry.id}/`}>← {seriesEntry.data.title}</a>
			</p>
		)
	}

	<!-- DEMO: side-by-side comparison. Pick one, delete the other. -->
	<p class="variant-label">Raw</p>
	<figure class="print-figure" data-invert="false">
		<div class="print-frame">
			<Image src={image} alt={alt} loading="eager" class="print-img" />
			<button
				type="button"
				class="invert-btn"
				aria-pressed="false"
				aria-label="Toggle negative"
				title="View as negative"
			>
				<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
					<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.6" />
					<path d="M 12 3 A 9 9 0 0 1 12 21 Z" fill="currentColor" />
				</svg>
			</button>
		</div>
		{caption && <figcaption>{caption}</figcaption>}
	</figure>

	<p class="variant-label">Matted</p>
	<figure class="print-figure print-figure-matted">
		<div class="print-mat">
			<Image src={image} alt={alt} loading="lazy" class="print-img" />
		</div>
		{caption && <figcaption>{caption}</figcaption>}
	</figure>

	<script is:inline>
		(function () {
			const figs = document.querySelectorAll(".print-figure");
			figs.forEach((fig) => {
				const btn = fig.querySelector(".invert-btn");
				if (!btn) return;
				btn.addEventListener("click", () => {
					const inverted = fig.getAttribute("data-invert") === "true";
					const next = !inverted;
					fig.setAttribute("data-invert", String(next));
					btn.setAttribute("aria-pressed", String(next));
					btn.setAttribute(
						"title",
						next ? "View as positive" : "View as negative",
					);
				});
			});
		})();
	</script>

	<h1>{title}</h1>

	<dl class="photo-meta">
		<dt>Date</dt>
		<dd>{fmt.format(date)}</dd>
		{location && (<><dt>Location</dt><dd>{location}</dd></>)}
		{camera && (<><dt>Camera</dt><dd>{camera}</dd></>)}
		{film && (<><dt>Film</dt><dd>{film}</dd></>)}
		{format && (<><dt>Format</dt><dd>{format.replace("x", "×")}</dd></>)}
	</dl>

	<section class="notes">
		<h2>Notes</h2>
		<Content />
	</section>

	{
		tags && tags.length > 0 && (
			<p class="photo-tags">
				{tags.map((t, i) => (
					<>
						{i > 0 && ", "}
						<a href={`/tags/${t}/`}>{t}</a>
					</>
				))}
			</p>
		)
	}
</Layout>

<style>
	.eyebrow {
		font-size: 0.8rem;
		color: var(--ink-faint);
		margin: 0 0 0.5rem;
	}

	.eyebrow a {
		text-decoration: none;
		color: inherit;
	}

	.eyebrow a:hover {
		color: var(--ink);
	}

	.variant-label {
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-faint);
		margin: 0 0 0.25rem;
	}

	.print-figure {
		margin: 0 0 2rem;
	}

	/* Matted variant — paper mat around the print, like a museum / framed wall print. */
	.print-figure-matted .print-mat {
		background: var(--paper-shadow);
		padding: 1.5rem 1.5rem 2.75rem;  /* heavier bottom — matting convention */
		box-shadow:
			inset 0 0 0 1px rgba(0, 0, 0, 0.06),
			0 1px 0 rgba(0, 0, 0, 0.04),
			0 12px 28px -10px rgba(0, 0, 0, 0.22);
		line-height: 0;
	}

	.print-figure-matted .print-img {
		display: block;
		width: 100%;
		height: auto;
	}

	.print-frame {
		position: relative;
		display: block;
		line-height: 0;
	}

	.print-img {
		display: block;
		width: 100%;
		height: auto;
		transition: filter 0.35s ease;
	}

	.print-figure[data-invert="true"] .print-img {
		filter: invert(1);
	}

	.invert-btn {
		position: absolute;
		bottom: 0.6rem;
		right: 0.6rem;
		width: 2rem;
		height: 2rem;
		padding: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: rgba(20, 17, 14, 0.55);
		color: #f3efe6;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 999px;
		cursor: pointer;
		transition: background-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
		backdrop-filter: blur(4px);
	}

	.invert-btn:hover {
		background: rgba(20, 17, 14, 0.82);
		border-color: rgba(255, 255, 255, 0.4);
	}

	.invert-btn:focus-visible {
		outline: 2px solid #f3efe6;
		outline-offset: 2px;
	}

	.print-figure[data-invert="true"] .invert-btn {
		transform: rotate(180deg);
	}

	dl.photo-meta {
		display: grid;
		grid-template-columns: max-content 1fr;
		gap: 0.3rem 1.25rem;
		color: var(--ink-soft);
		font-size: 0.8rem;
		margin: 1rem 0 1.5rem;
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		letter-spacing: 0.04em;
	}

	dl.photo-meta dt {
		color: var(--ink-faint);
		text-transform: uppercase;
		font-size: 0.7rem;
		padding-top: 0.1rem;
	}

	dl.photo-meta dd {
		margin: 0;
	}

	section.notes h2 {
		font-size: 1rem;
		margin: 0 0 0.4rem;
	}

	.photo-tags {
		margin: 2rem 0 0;
		color: var(--ink-faint);
		font-size: 0.85rem;
	}

	.photo-tags a {
		color: var(--ink-soft);
		text-decoration: none;
		border-bottom: 1px dotted var(--rule);
	}

	.photo-tags a:hover {
		color: var(--ink);
		border-bottom-color: var(--ink-faint);
	}
</style>

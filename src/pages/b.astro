---
import { Image } from "astro:assets";
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { formatLabel } from "../lib/format";

const allSeries = (await getCollection("series", ({ data }) => !data.draft)).sort(
	(a, b) => a.data.order - b.data.order,
);
const allPhotos = (await getCollection("photos", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const hero = allPhotos[0];
const heroSeries = hero?.data.series ? await getEntry(hero.data.series) : null;

const fmtYear = new Intl.DateTimeFormat("en-US", { year: "numeric" });
const fmtMonthYear = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });

const seriesData = await Promise.all(
	allSeries.map(async (series) => {
		const photos = allPhotos.filter((p) => p.data.series?.id === series.id);
		const dates = photos.map((p) => p.data.date.valueOf());
		const earliest = dates.length ? new Date(Math.min(...dates)) : null;
		const latest = dates.length ? new Date(Math.max(...dates)) : null;
		const range =
			earliest && latest
				? earliest.getFullYear() === latest.getFullYear()
					? fmtYear.format(latest)
					: `${fmtYear.format(earliest)}–${fmtYear.format(latest)}`
				: "";
		return { series, count: photos.length, range };
	}),
);
---

<Layout title="Chris Bendel — Photography (B)" description="Latest print, then series.">
	{
		hero && (
			<a href={`/photos/${hero.id}/`} class="variant-b-hero">
				<figure>
					<Image
						src={hero.data.image}
						alt={hero.data.alt}
						widths={[640, 960, 1280, 1600]}
						sizes="(min-width: 700px) 36rem, 100vw"
						loading="eager"
					/>
					<figcaption>
						<span class="hero-title">{hero.data.title}</span>
						<span class="hero-meta">
							{[
								heroSeries?.data.title,
								hero.data.format && formatLabel(hero.data.format),
								fmtMonthYear.format(hero.data.date),
							]
								.filter(Boolean)
								.join(" · ")}
						</span>
					</figcaption>
				</figure>
			</a>
		)
	}

	<section class="variant-b-footer">
		<p class="footer-eyebrow">Series</p>
		<ul class="variant-b-series-list">
			{
				seriesData.map(({ series, count, range }) => (
					<li>
						<a href={`/series/${series.id}/`}>
							<span class="series-name">{series.data.title}</span>
							<span class="series-stat-inline">
								{count} print{count === 1 ? "" : "s"}
								{range && ` · ${range}`}
							</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

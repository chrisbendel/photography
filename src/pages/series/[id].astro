---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const allSeries = await getCollection("series", ({ data }) => !data.draft);
	const allPhotos = await getCollection("photos", ({ data }) => !data.draft);

	return allSeries.map((series) => {
		// Newest first — top of the stack
		const photos = allPhotos
			.filter((p) => p.data.series?.id === series.id)
			.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
		return {
			params: { id: series.id },
			props: { series, photos },
		};
	});
}

const { series, photos } = Astro.props;
const fmtYear = new Intl.DateTimeFormat("en-US", { year: "numeric" });

const dates = photos.map((p) => p.data.date.valueOf());
const earliest = dates.length ? new Date(Math.min(...dates)) : null;
const latest = dates.length ? new Date(Math.max(...dates)) : null;
const range =
	earliest && latest
		? earliest.getFullYear() === latest.getFullYear()
			? fmtYear.format(latest)
			: `${fmtYear.format(earliest)}–${fmtYear.format(latest)}`
		: "";
---

<Layout title={`${series.data.title} — Chris Bendel`} description={series.data.description}>
	<section class="intro">
		<p class="eyebrow"><a href="/series/">← Series</a></p>
		<h1>{series.data.title}</h1>
	</section>

	{
		photos.length === 0 ? (
			<p><em>No photographs in this box yet.</em></p>
		) : (
			<div class="print-stack">
				{photos.map((photo) => (
					<a class="print-entry" href={`/photos/${photo.id}/`} id={photo.id}>
						<div class="print-mount">
							<figure>
								<Image src={photo.data.image} alt={photo.data.alt} loading="lazy" />
								{photo.data.caption && <figcaption>{photo.data.caption}</figcaption>}
							</figure>
						</div>
					</a>
				))}
			</div>
		)
	}

</Layout>

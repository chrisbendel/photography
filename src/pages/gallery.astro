---
import { Image, getImage } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { byNewest } from "../lib/format";

const allPhotos = (await getCollection("photos")).sort(byNewest);

// Build per-photo data + a 1600w large variant URL for the loupe
const photoData = await Promise.all(
	allPhotos.map(async (p) => {
		const large = await getImage({ src: p.data.image, width: 1600 });
		return {
			id: p.id,
			alt: p.data.alt,
			largeSrc: large.src,
		};
	}),
);

const loupeJson = JSON.stringify(photoData);
---

<Layout title="Gallery — Chris Bendel" description="Every photograph, at a glance.">
	<div class="sheet" id="gallery-grid">
		{
			allPhotos.map((photo) => (
				<button
					type="button"
					class="cell"
					data-loupe-id={photo.id}
					aria-label={`Open photograph ${photo.id}`}
				>
					<Image
						src={photo.data.image}
						alt={photo.data.alt}
						widths={[400, 800, 1200]}
						sizes="(min-width: 900px) 11rem, (min-width: 600px) 16rem, 90vw"
						loading="lazy"
					/>
				</button>
			))
		}
	</div>
</Layout>

<div
	class="loupe"
	id="loupe"
	hidden
	role="dialog"
	aria-modal="true"
	aria-label="Print viewer"
>
	<button class="loupe-btn loupe-close" type="button" aria-label="Close (Esc)">
		<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
			<path d="M6 6l12 12M18 6l-12 12" />
		</svg>
	</button>
	<button class="loupe-btn loupe-prev" type="button" aria-label="Previous (←)">
		<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
			<polyline points="15 4 7 12 15 20" />
		</svg>
	</button>
	<button class="loupe-btn loupe-next" type="button" aria-label="Next (→)">
		<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
			<polyline points="9 4 17 12 9 20" />
		</svg>
	</button>
	<figure class="loupe-stage">
		<img id="loupe-img" alt="" />
		<figcaption class="loupe-caption">
			<span id="loupe-position" class="loupe-position"></span>
			<a id="loupe-permalink" class="loupe-details" href="#">Details</a>
		</figcaption>
	</figure>
</div>

<style>
	/* Grid cells use <button> instead of <a> — strip default button chrome */
	.sheet button.cell {
		background: none;
		border: 0;
		padding: 0;
		cursor: zoom-in;
		font: inherit;
		color: inherit;
	}

	/* Loupe overlay — appears above the grid when a thumb is clicked */
	.loupe {
		position: fixed;
		inset: 0;
		z-index: 100;
		background: color-mix(in srgb, var(--paper) 92%, transparent);
		display: grid;
		grid-template-columns: auto 1fr auto;
		grid-template-rows: 1fr auto;
		gap: 0;
		align-items: center;
		justify-items: center;
		padding: 4vh 4vw;
		cursor: zoom-out;
		animation: loupe-fade 0.18s ease;
		color: var(--ink);
	}

	@keyframes loupe-fade {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	.loupe[hidden] {
		display: none;
	}

	.loupe-stage {
		grid-column: 2;
		grid-row: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		max-width: 100%;
		max-height: 100%;
		cursor: default;
		margin: 0;
	}

	.loupe-stage img {
		max-width: 100%;
		max-height: calc(92vh - 5rem);
		height: auto;
		width: auto;
		display: block;
		box-shadow: 0 24px 60px -12px rgba(0, 0, 0, 0.6);
	}

	.loupe-caption {
		color: var(--ink);
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.loupe-position {
		color: var(--ink-faint);
	}

	.loupe-details {
		color: var(--ink);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
	}

	.loupe-details:hover {
		text-decoration-thickness: 2px;
	}

	.loupe-btn {
		background: color-mix(in srgb, var(--ink) 8%, transparent);
		border: 1px solid color-mix(in srgb, var(--ink) 22%, transparent);
		color: var(--ink);
		padding: 0.5rem;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		width: 2.5rem;
		height: 2.5rem;
		transition: background-color 0.12s ease, border-color 0.12s ease;
	}

	.loupe-btn:hover {
		background: color-mix(in srgb, var(--ink) 16%, transparent);
		border-color: color-mix(in srgb, var(--ink) 50%, transparent);
	}

	.loupe-btn:focus-visible {
		outline: 2px solid var(--ink);
		outline-offset: 2px;
	}

	.loupe-close {
		position: fixed;
		top: 1.25rem;
		right: 1.25rem;
	}

	.loupe-prev {
		grid-column: 1;
		grid-row: 1;
		justify-self: start;
		align-self: center;
	}

	.loupe-next {
		grid-column: 3;
		grid-row: 1;
		justify-self: end;
		align-self: center;
	}

	@media (max-width: 600px) {
		.loupe {
			padding: 3vh 1rem;
			grid-template-columns: 1fr;
			grid-template-rows: 1fr auto;
		}
		.loupe-stage {
			grid-column: 1;
			grid-row: 1;
		}
		.loupe-prev,
		.loupe-next {
			grid-row: 2;
			grid-column: 1;
			align-self: end;
		}
		.loupe-prev {
			justify-self: start;
		}
		.loupe-next {
			justify-self: end;
		}
	}
</style>

<script id="loupe-data" type="application/json" set:html={loupeJson}></script>

<script is:inline>
	(function () {
		const dataEl = document.getElementById("loupe-data");
		if (!dataEl) return;
		const photos = JSON.parse(dataEl.textContent || "[]");
		if (photos.length === 0) return;

		const loupe = document.getElementById("loupe");
		const img = document.getElementById("loupe-img");
		const permalink = document.getElementById("loupe-permalink");
		const position = document.getElementById("loupe-position");
		const grid = document.getElementById("gallery-grid");
		const btnClose = loupe?.querySelector(".loupe-close");
		const btnPrev = loupe?.querySelector(".loupe-prev");
		const btnNext = loupe?.querySelector(".loupe-next");

		if (!loupe || !img || !permalink || !position || !grid) return;

		let currentIdx = -1;

		function indexById(id) {
			return photos.findIndex((p) => p.id === id);
		}

		function open(idx) {
			if (idx < 0 || idx >= photos.length) return;
			currentIdx = idx;
			const p = photos[idx];
			img.src = p.largeSrc;
			img.alt = p.alt;
			permalink.href = "/photos/" + p.id + "/";
			position.textContent = idx + 1 + " / " + photos.length;
			loupe.hidden = false;
			document.body.style.overflow = "hidden";
			if (location.hash !== "#" + p.id) {
				history.replaceState(null, "", "#" + p.id);
			}
			// Preload neighbors
			const preload = (i) => {
				if (i < 0 || i >= photos.length) return;
				const im = new Image();
				im.src = photos[i].largeSrc;
			};
			preload(idx - 1);
			preload(idx + 1);
		}

		function close() {
			loupe.hidden = true;
			document.body.style.overflow = "";
			currentIdx = -1;
			if (location.hash) {
				history.replaceState(null, "", location.pathname + location.search);
			}
		}

		function step(delta) {
			if (currentIdx === -1) return;
			const next = (currentIdx + delta + photos.length) % photos.length;
			open(next);
		}

		grid.addEventListener("click", (e) => {
			const btn = e.target.closest("[data-loupe-id]");
			if (!btn) return;
			const id = btn.getAttribute("data-loupe-id");
			const idx = indexById(id);
			if (idx !== -1) open(idx);
		});

		btnClose?.addEventListener("click", close);
		btnPrev?.addEventListener("click", () => step(-1));
		btnNext?.addEventListener("click", () => step(1));

		loupe.addEventListener("click", (e) => {
			// Click on backdrop (loupe itself), not on stage or buttons
			if (e.target === loupe) close();
		});

		document.addEventListener("keydown", (e) => {
			if (loupe.hidden) return;
			if (e.key === "Escape") {
				e.preventDefault();
				close();
			} else if (e.key === "ArrowLeft") {
				e.preventDefault();
				step(-1);
			} else if (e.key === "ArrowRight") {
				e.preventDefault();
				step(1);
			}
		});

		// Open from URL hash on load
		if (location.hash.length > 1) {
			const idx = indexById(location.hash.slice(1));
			if (idx !== -1) open(idx);
		}

		window.addEventListener("hashchange", () => {
			if (location.hash.length > 1) {
				const idx = indexById(location.hash.slice(1));
				if (idx !== -1 && idx !== currentIdx) open(idx);
			} else if (!loupe.hidden) {
				close();
			}
		});
	})();
</script>

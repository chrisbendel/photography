---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const photos = await getCollection("photos", ({ data }) => !data.draft);
const counts = new Map<string, number>();
for (const p of photos) {
	for (const t of p.data.tags ?? []) {
		counts.set(t, (counts.get(t) ?? 0) + 1);
	}
}

const tags = [...counts.entries()].sort(
	(a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
---

<Layout title="Tags — Chris Bendel" description="Browse photographs by tag.">
	{
		tags.length === 0 ? (
			<p><em>No tags yet.</em></p>
		) : (
			<>
				<div class="tag-search">
					<label for="tag-filter" class="visually-hidden">Filter tags</label>
					<input
						id="tag-filter"
						type="search"
						placeholder="Filter tags…"
						autocomplete="off"
						spellcheck="false"
					/>
					<p id="tag-filter-status" class="tag-search-status" aria-live="polite">
						{tags.length} tag{tags.length === 1 ? "" : "s"}
					</p>
				</div>

				<ul class="tag-cloud" id="tag-cloud">
					{tags.map(([tag, count]) => (
						<li data-tag={tag}>
							<a href={`/tags/${tag}/`}>
								#{tag} <span class="count">{count}</span>
							</a>
						</li>
					))}
				</ul>

				<script is:inline>
					(function () {
						const input = document.getElementById("tag-filter");
						const cloud = document.getElementById("tag-cloud");
						const status = document.getElementById("tag-filter-status");
						if (!input || !cloud || !status) return;

						const items = Array.from(cloud.querySelectorAll("li"));
						const total = items.length;

						function applyFilter() {
							const q = input.value.trim().toLowerCase();
							let shown = 0;
							for (const li of items) {
								const tag = (li.dataset.tag || "").toLowerCase();
								const match = !q || tag.includes(q);
								li.hidden = !match;
								if (match) shown++;
							}
							status.textContent =
								q === ""
									? `${total} tag${total === 1 ? "" : "s"}`
									: `${shown} of ${total} match`;
						}

						input.addEventListener("input", applyFilter);
						input.addEventListener("search", applyFilter);
					})();
				</script>
			</>
		)
	}
</Layout>

<style>
	.visually-hidden {
		position: absolute !important;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.tag-search {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin: 1.5rem 0 1.25rem;
		flex-wrap: wrap;
	}

	.tag-search input[type="search"] {
		flex: 1;
		min-width: 12rem;
		background: transparent;
		border: 0;
		border-bottom: 1px solid var(--rule);
		color: var(--ink);
		font: inherit;
		font-size: 1rem;
		padding: 0.4rem 0;
		outline: none;
	}

	.tag-search input[type="search"]:focus {
		border-bottom-color: var(--ink);
	}

	.tag-search input[type="search"]::placeholder {
		color: var(--ink-faint);
		font-style: italic;
	}

	.tag-search-status {
		margin: 0;
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-faint);
	}

	ul.tag-cloud {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	ul.tag-cloud a {
		display: inline-block;
		padding: 0.35rem 0.7rem;
		border: 1px solid var(--rule);
		font-size: 0.85rem;
		color: var(--ink-soft);
		text-decoration: none;
		letter-spacing: 0.04em;
	}

	ul.tag-cloud a:hover {
		color: var(--ink);
		border-color: var(--ink);
	}

	ul.tag-cloud .count {
		color: var(--ink-faint);
		font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
		font-size: 0.75rem;
		margin-left: 0.3rem;
	}
</style>

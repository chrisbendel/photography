---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const photos = await getCollection("photos");
	const byTag = new Map();
	for (const p of photos) {
		for (const t of p.data.tags ?? []) {
			if (!byTag.has(t)) byTag.set(t, []);
			byTag.get(t).push(p);
		}
	}
	return [...byTag.entries()].map(([tag, ps]) => ({
		params: { tag },
		props: {
			tag,
			photos: ps.sort((a, b) => b.id.localeCompare(a.id)),
		},
	}));
}

const { tag, photos } = Astro.props;
---

<Layout title={`#${tag} — Chris Bendel`} description={`Photographs tagged ${tag}.`}>
	<h1>#{tag}</h1>

	<div class="sheet">
		{
			photos.map((photo) => (
				<a href={`/photos/${photo.id}/`} class="cell" aria-label={`Photograph ${photo.id}`}>
					<Image
						src={photo.data.image}
						alt={photo.data.alt}
						widths={[400, 800, 1200]}
						sizes="(min-width: 900px) 11rem, (min-width: 600px) 16rem, 90vw"
						loading="lazy"
					/>
				</a>
			))
		}
	</div>
</Layout>

---
const links = [
	{ href: "/gallery/", label: "Gallery" },
	{ href: "/series/", label: "Series" },
	{ href: "/tags/", label: "Tags" },
	// Future: { href: "/shop", label: "Shop" },
	// Future: { href: "/about", label: "About" },
];

const path = Astro.url.pathname;
const isCurrent = (href: string) => path.startsWith(href);
---

<header class="site">
	<nav class="site-nav" aria-label="Primary">
		<a href="/" class="brand" aria-label="Chris Bendel — home">
			<svg
				class="brand-mark"
				viewBox="0 0 32 40"
				aria-hidden="true"
				focusable="false"
			>
				<defs>
					<clipPath id="brand-mark-clip">
						<path d="M 0 0 L 9 0 L 9 5 L 13 5 L 13 0 L 15 0 L 15 5 L 17 5 L 17 0 L 23 0 L 23 5 L 27 5 L 27 0 L 32 0 L 32 40 L 0 40 Z" />
					</clipPath>
				</defs>
				<path
					class="mark-sheet"
					d="M 0 0 L 9 0 L 9 5 L 13 5 L 13 0 L 15 0 L 15 5 L 17 5 L 17 0 L 23 0 L 23 5 L 27 5 L 27 0 L 32 0 L 32 40 L 0 40 Z"
				/>
				<g clip-path="url(#brand-mark-clip)">
					<circle class="mark-img" cx="9" cy="17" r="2.2" opacity="0.5" />
					<path
						class="mark-img"
						opacity="0.35"
						d="M 0 28 L 5 24 L 10 27 L 14 22 L 19 26 L 24 23 L 32 27 L 32 30 L 0 30 Z"
					/>
					<path
						class="mark-img"
						opacity="0.6"
						d="M 0 33 L 7 24 L 13 30 L 18 21 L 24 28 L 32 25 L 32 36 L 0 36 Z"
					/>
					<rect class="mark-img" x="0" y="36" width="32" height="4" opacity="0.4" />
				</g>
			</svg>
			<span class="brand-name">Chris Bendel</span>
		</a>
		<ul>
			{
				links.map(({ href, label }) => (
					<li>
						<a href={href} aria-current={isCurrent(href) ? "page" : undefined}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<button
			type="button"
			class="darkroom-pull"
			id="theme-pull"
			aria-label="Toggle darkroom light"
			title="Turn light on/off"
		>
			<svg viewBox="0 0 28 44" aria-hidden="true" focusable="false">
				<!-- soft outer glow halo (largest, blurriest) -->
				<circle class="halo halo-outer" cx="14" cy="32" r="14" />
				<!-- inner glow halo -->
				<circle class="halo halo-inner" cx="14" cy="32" r="9" />
				<!-- ceiling anchor -->
				<circle class="anchor" cx="14" cy="0.6" r="0.9" />
				<!-- cord -->
				<g class="cord-group">
					<line class="cord" x1="14" y1="0" x2="14" y2="20" />
					<!-- pull-knob at end of cord -->
					<circle class="knob" cx="14" cy="21" r="1.1" />
				</g>
				<!-- bulb hanging from cord -->
				<g class="bulb-group">
					<!-- screw cap -->
					<rect class="cap" x="11.5" y="22.5" width="5" height="2.6" rx="0.4" />
					<!-- glass envelope -->
					<ellipse class="glass" cx="14" cy="32" rx="5.8" ry="6.6" />
					<!-- filament: classic figure-8 zigzag -->
					<path
						class="filament"
						d="M 11 31 Q 12.5 33 14 31 Q 15.5 29 17 31 Q 15.5 33.5 14 32 Q 12.5 30.5 11 32 Z"
						fill="none"
					/>
					<!-- highlight on glass when lit (subtle reflection) -->
					<ellipse class="highlight" cx="11.5" cy="29.5" rx="1.1" ry="1.8" />
				</g>
			</svg>
		</button>
	</nav>
</header>

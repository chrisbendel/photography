---
const links = [
	{ href: "/gallery/", label: "Gallery" },
	{ href: "/tags/", label: "Tags" },
	// Future: { href: "/shop", label: "Shop" },
	// Future: { href: "/about", label: "About" },
];

const demos = [
	{ href: "/d/", label: "D" },
	{ href: "/e/", label: "E" },
];

const path = Astro.url.pathname;
const isCurrent = (href: string) => path.startsWith(href);
---

<header class="site">
	<nav class="site-nav" aria-label="Primary">
		<a href="/" class="brand" aria-label="Chris Bendel — home">
			<svg
				class="brand-mark"
				viewBox="0 0 32 40"
				aria-hidden="true"
				focusable="false"
			>
				<defs>
					<clipPath id="brand-mark-clip">
						<path d="M 0 0 L 9 0 L 9 5 L 13 5 L 13 0 L 15 0 L 15 5 L 17 5 L 17 0 L 23 0 L 23 5 L 27 5 L 27 0 L 32 0 L 32 40 L 0 40 Z" />
					</clipPath>
				</defs>
				<path
					class="mark-sheet"
					d="M 0 0 L 9 0 L 9 5 L 13 5 L 13 0 L 15 0 L 15 5 L 17 5 L 17 0 L 23 0 L 23 5 L 27 5 L 27 0 L 32 0 L 32 40 L 0 40 Z"
				/>
				<g clip-path="url(#brand-mark-clip)">
					<circle class="mark-img" cx="9" cy="17" r="2.2" opacity="0.5" />
					<path
						class="mark-img"
						opacity="0.35"
						d="M 0 28 L 5 24 L 10 27 L 14 22 L 19 26 L 24 23 L 32 27 L 32 30 L 0 30 Z"
					/>
					<path
						class="mark-img"
						opacity="0.6"
						d="M 0 33 L 7 24 L 13 30 L 18 21 L 24 28 L 32 25 L 32 36 L 0 36 Z"
					/>
					<rect class="mark-img" x="0" y="36" width="32" height="4" opacity="0.4" />
				</g>
			</svg>
			<span class="brand-name">Chris Bendel</span>
		</a>
		<ul>
			{
				links.map(({ href, label }) => (
					<li>
						<a href={href} aria-current={isCurrent(href) ? "page" : undefined}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<ul class="demo-links" aria-label="Homepage variants">
			{
				demos.map(({ href, label }) => (
					<li>
						<a href={href} aria-current={isCurrent(href) ? "page" : undefined}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<button
			type="button"
			class="theme-toggle"
			id="theme-toggle"
			aria-label="Toggle color theme"
		>
			<svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
			</svg>
			<svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4" />
				<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
			</svg>
		</button>
	</nav>
</header>
